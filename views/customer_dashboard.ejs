<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Dashboard | Rupya AI</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">


<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="#">
            Rupya AI
        </a>

        <div class="ms-auto">
            <span class="text-white">
                Welcome, <%= customer.name %>
            </span>
        </div>
    </div>
</nav>

<div class="container mt-5">

    <div class="mb-4">
        <h1>Customer Dashboard</h1>
        <p class="text-muted">
            Manage your loan applications and track their progress.
        </p>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h4 class="mb-3">Quick Actions</h4>

            <a href="/customer/apply-loan" class="btn btn-primary me-2">
                Apply for Loan
            </a>

            <a href="/customer/loan-status" class="btn btn-outline-primary">
                Track Application
            </a>

        </div>
    </div>

    <div class="row mb-4">

        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6>Total Applications</h6>
                    <h2><%= loanSummary.totalApplications %></h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6>Under Review</h6>
                    <h2><%= loanSummary.underReview %></h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6>Approved</h6>
                    <h2><%= loanSummary.approvedApplications %></h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6>Rejected</h6>
                    <h2><%= loanSummary.rejectedApplications %></h2>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-header">
            <h4 class="mb-0">Recent Applications</h4>
        </div>

        <div class="card-body">

            <table class="table table-hover">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Loan Type</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>

                <% recentApplications.forEach(application => { %>

                    <tr>
                        <td><%= application.applicationID %></td>
                        <td><%= application.loanType %></td>
                        <td><%= application.applicationDate %></td>
                        <td>₹<%= application.amount %></td>
                        <td><%= application.status %></td>
                    </tr>

                <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</div>
</body>
</html>
