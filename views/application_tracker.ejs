<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Application Tracker | Rupya AI</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">

        <a class="navbar-brand fw-bold" href="#">
            Rupya AI
        </a>

        <a href="/customer/dashboard" class="btn btn-outline-light">
            Dashboard
        </a>

    </div>
</nav>

<div class="container mt-5">

    <div class="mb-4">
        <h1>Application Tracker</h1>

        <p class="text-muted">
            View the status of all your submitted loan applications.
        </p>
    </div>

    <div class="card shadow-sm">

        <div class="card-header">
            <h4 class="mb-0">Applications</h4>
        </div>

        <div class="card-body">

            <table class="table table-striped table-hover">

                <thead>
                    <tr>
                        <th>Application ID</th>
                        <th>Loan Type</th>
                        <th>Application Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>

                <% applications.forEach(application => { %>

                    <tr>
                        <td><%= application.applicationID %></td>
                        <td><%= application.loanType %></td>
                        <td><%= application.applicationDate %></td>
                        <td>₹<%= application.amount %></td>
                        <td><%= application.status %></td>
                    </tr>

                <% }) %>

                </tbody>
            </table>

        </div>
    </div>
</div>
</body>
</html>
