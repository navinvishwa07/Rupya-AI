<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loan Application | Step 5</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">

    <div class="container">

        <a class="navbar-brand fw-bold" href="/customer/dashboard">
            Rupya AI
        </a>

    </div>

</nav>

<div class="container mt-5">

    <div class="row">

        <div class="col-md-3">

            <div class="card shadow-sm">

                <div class="card-header">
                    <h5>Application Progress</h5>
                </div>

                <div class="card-body">

                    <p class="text-success">✔ Personal Information</p>
                    <p class="text-success">✔ Loan Details</p>
                    <p class="text-success">✔ Employment</p>
                    <p class="text-success">✔ Financial Information</p>
                    <p><strong>Step 5</strong> Credit Information</p>
                    <p>○ Review & Submit</p>

                </div>

            </div>

        </div>

        <div class="col-md-9">

            <div class="card shadow">

                <div class="card-header">

                    <h3>Step 5 - Credit Information</h3>

                    <small class="text-muted">
                        Provide the credit details required to support AI underwriting.
                    </small>

                </div>

                <div class="card-body">

                    <form action="/customer/apply-loan/step6" method="GET">

                        <div class="row">

                            <div class="col-lg-8">

                                <div class="mb-4">
                                    <h5 class="mb-3">Existing Credit</h5>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Number of Credit Cards</label>
                                            <input
                                                type="number"
                                                min="0"
                                                class="form-control border border-dark"
                                                name="creditCards">
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Total Credit Limit</label>
                                            <input
                                                type="number"
                                                min="0"
                                                class="form-control border border-dark"
                                                name="creditLimit">
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Current Credit Utilization</label>
                                            <input
                                                type="number"
                                                min="0"
                                                max="100"
                                                class="form-control border border-dark"
                                                name="creditUtilization">
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Existing Personal Loans</label>
                                            <input
                                                type="text"
                                                class="form-control border border-dark"
                                                name="personalLoanCount">
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Home Loan</label>
                                            <input
                                                type="text"
                                                class="form-control border border-dark"
                                                name="homeLoan">
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Vehicle Loan</label>
                                            <input
                                                type="text"
                                                class="form-control border border-dark"
                                                name="vehicleLoan">
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Education Loan</label>
                                            <input
                                                type="text"
                                                class="form-control border border-dark"
                                                name="educationLoan">
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Business Loan</label>
                                            <input
                                                type="text"
                                                class="form-control border border-dark"
                                                name="businessLoan">
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <h5 class="mb-3">Repayment History</h5>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Any previous defaults?</label>
                                            <select
                                                class="form-select border border-dark"
                                                name="previousDefaults">

                                                <option value="">Select</option>
                                                <option>Yes</option>
                                                <option>No</option>

                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Any loan settlement?</label>
                                            <select
                                                class="form-select border border-dark"
                                                name="loanSettlement">

                                                <option value="">Select</option>
                                                <option>Yes</option>
                                                <option>No</option>

                                            </select>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Any bankruptcy?</label>
                                            <select
                                                class="form-select border border-dark"
                                                name="bankruptcy">

                                                <option value="">Select</option>
                                                <option>Yes</option>
                                                <option>No</option>

                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Missed EMI in last 12 months?</label>
                                            <select
                                                class="form-select border border-dark"
                                                name="missedEmi">

                                                <option value="">Select</option>
                                                <option>Yes</option>
                                                <option>No</option>

                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Number of credit enquiries in last six months</label>
                                        <input
                                            type="number"
                                            min="0"
                                            class="form-control border border-dark"
                                            name="creditEnquiries">
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <h5 class="mb-3">Consent</h5>

                                    <div class="form-check">
                                        <input
                                            class="form-check-input"
                                            type="checkbox"
                                            id="creditConsent"
                                            name="creditConsent"
                                            required>
                                        <label class="form-check-label" for="creditConsent">
                                            I authorize Rupya AI to retrieve my credit report.
                                        </label>
                                    </div>
                                </div>

                            </div>

                            <div class="col-lg-4">
                                <div class="card border-secondary shadow-sm mb-4">
                                    <div class="card-header bg-white">
                                        <h5 class="mb-0">AI Preview</h5>
                                    </div>
                                    <div class="card-body">
                                        <p class="text-muted mb-3">Will be calculated after submission.</p>

                                        <div class="mb-3">
                                            <p class="text-muted mb-1">Current Credit Score</p>
                                            <h5 class="mb-0">742</h5>
                                        </div>
                                        <div class="mb-3">
                                            <p class="text-muted mb-1">Credit Utilization</p>
                                            <h5 class="mb-0">28%</h5>
                                        </div>
                                        <div>
                                            <p class="text-muted mb-1">Payment History</p>
                                            <h5 class="mb-0">Excellent</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/customer/apply-loan/step4" class="btn btn-secondary">
                                Previous
                            </a>

                            <div>
                                <button type="submit" class="btn btn-outline-secondary me-2">
                                    Save Draft
                                </button>
                                <button type="submit" class="btn btn-primary">
                                    Save & Next
                                </button>
                            </div>
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

</body>

</html>
